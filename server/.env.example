# Neon PostgreSQL connection string — paste yours here (Neon dashboard → Connection string).
# Use the pooled connection string and keep ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# JWT signing secret for session tokens.
JWT_SECRET="HACKCLUB_VIT_SECRET_SESSION_TOKEN_KEY_2026"

# Gmail SMTP credentials for sending OTP emails (App Password, not your login password).
SMTP_USER="your-email@gmail.com"
SMTP_PASS=""

# Server port (optional, defaults to 5000).
PORT=5000
